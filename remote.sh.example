#!/usr/bin/bash
# Copy to remote.sh and edit. remote.sh is gitignored.
#   cp remote.sh.example remote.sh

# --- Slurm resources ---
export JWM_GPU_NUM=4
export JWM_NODES_NUM=1
export JWM_RUN_TIME="1-00:00:00"
# export JWM_GPU_TYPE=A40      # auto-detected if unset

# --- Run tag (optional) ---
# Distinguishes multiple runs under the same commit.
# If unset, meta_script.sh auto-generates a timestamp.
# export JWM_RUN_TAG="final_all_exps"
